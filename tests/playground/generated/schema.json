{
  "process": "order-pipeline",
  "version": 1,
  "process_input": {
    "$ref": "#/$defs/input"
  },
  "process_output": {
    "$ref": "#/$defs/output"
  },
  "tasks": {
    "recursion": {
      "call_type": "child_process",
      "input": {
        "type": "object"
      },
      "output": {
        "$ref": "#/$defs/recursion_output"
      }
    }
  },
  "$defs": {
    "input": {
      "properties": {
        "root": {
          "type": "boolean"
        },
        "ttl": {
          "type": "integer"
        }
      },
      "required": [
        "ttl"
      ],
      "type": "object"
    },
    "output": {
      "properties": {
        "processes": {
          "type": "number"
        }
      },
      "required": [
        "processes"
      ],
      "type": "object"
    },
    "recursion_output": {
      "items": {
        "properties": {
          "id": {
            "type": "string"
          },
          "output": {
            "properties": {
              "processes": {
                "type": "number"
              }
            },
            "required": [
              "processes"
            ],
            "type": "object"
          }
        },
        "required": [
          "id",
          "output"
        ],
        "type": "object"
      },
      "type": "array"
    }
  }
}
