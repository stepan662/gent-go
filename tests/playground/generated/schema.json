{
  "process": "order-pipeline",
  "version": 0,
  "process_output": {
    "$ref": "#/$defs/output"
  },
  "tasks": {
    "finale": {
      "call_type": "rest",
      "input": {
        "$ref": "#/$defs/finale_input"
      },
      "output": {
        "$ref": "#/$defs/finale_output"
      }
    },
    "start": {
      "call_type": "rest",
      "input": {
        "type": "object"
      },
      "output": {
        "$ref": "#/$defs/start_output"
      }
    }
  },
  "$defs": {
    "finale_input": {
      "type": "object",
      "properties": {
        "error": {
          "type": "string"
        }
      },
      "required": [
        "error"
      ]
    },
    "finale_output": {
      "type": "object",
      "properties": {
        "ok": {
          "type": "boolean"
        }
      },
      "required": [
        "ok"
      ]
    },
    "output": {
      "type": "object",
      "properties": {
        "is_ok": {
          "type": "boolean"
        }
      },
      "required": [
        "is_ok"
      ]
    },
    "start_output": {
      "type": "object",
      "properties": {
        "ok": {
          "type": "boolean"
        }
      },
      "required": [
        "ok"
      ]
    }
  }
}
