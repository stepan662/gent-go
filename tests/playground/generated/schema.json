{
  "process": "order-pipeline",
  "tasks": {
    "failure": {
      "call_type": "rest",
      "input": {
        "$ref": "#/$defs/failure_input"
      }
    },
    "start": {
      "call_type": "child_process",
      "input": {
        "type": "object"
      },
      "output": {
        "$ref": "#/$defs/start_output"
      }
    },
    "success": {
      "call_type": "rest",
      "input": {
        "type": "object"
      },
      "output": {
        "$ref": "#/$defs/success_output"
      }
    }
  },
  "$defs": {
    "failure_input": {
      "type": "object",
      "properties": {
        "error": {
          "type": "string"
        }
      },
      "required": [
        "error"
      ]
    },
    "start_output": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          }
        },
        "required": [
          "id"
        ]
      }
    },
    "success_output": {
      "type": "object",
      "properties": {
        "ok": {
          "type": "boolean"
        }
      },
      "required": [
        "ok"
      ]
    }
  }
}
