{
  "process": "order-pipeline",
  "version": 1,
  "process_input": {
    "$ref": "#/$defs/input"
  },
  "process_output": {
    "$ref": "#/$defs/output"
  },
  "tasks": {
    "finish": {
      "call_type": "child_process",
      "input": {
        "type": "object"
      },
      "output": {
        "$ref": "#/$defs/finish_output"
      }
    },
    "recursion": {
      "call_type": "child_process",
      "input": {
        "type": "object"
      },
      "output": {
        "$ref": "#/$defs/recursion_output"
      }
    }
  },
  "$defs": {
    "finish_output": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          }
        },
        "required": [
          "id"
        ]
      }
    },
    "input": {
      "type": "object",
      "properties": {
        "ttl": {
          "type": "integer"
        }
      },
      "required": [
        "ttl"
      ]
    },
    "output": {
      "type": "object",
      "properties": {
        "processes": {
          "type": "number"
        }
      },
      "required": [
        "processes"
      ]
    },
    "recursion_output": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "output": {
            "type": "object",
            "properties": {
              "processes": {
                "type": "number"
              }
            },
            "required": [
              "processes"
            ]
          }
        },
        "required": [
          "id",
          "output"
        ]
      }
    }
  }
}
